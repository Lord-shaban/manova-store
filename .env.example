# نسخة نموذجية لمتغيرات البيئة — انسخها إلى .env واملأ القيم
# (ملف .env لا يُرفع على جيت هب)

# منفذ التشغيل (الاستضافات بتحدده تلقائيًا غالبًا)
PORT=3000

# مسار حفظ قاعدة البيانات — على الاستضافة اضبطه على مسار القرص الدائم
# مثال على Render: /var/data
DATA_DIR=

# مسار حفظ الصور المرفوعة — يُفضّل يكون داخل القرص الدائم كمان
# مثال على Render: /var/data/uploads
UPLOADS_DIR=

# بيانات دخول المدير الأولى (تُستخدم مرة واحدة عند أول تشغيل لإنشاء القاعدة)
# غيّرها لقيم قوية قبل النشر — وبعد الدخول غيّر كلمة المرور من لوحة التحكم
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-strong-password
